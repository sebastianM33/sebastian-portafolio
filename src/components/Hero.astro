  <div class="contenido-principal">
    <TituloAnimado texto="Desarrollador Full Stack" velocidad={100} client:load />
    <p class="subtitulo-principal" id="hero-subtitle">
      Creando experiencias digitales increíbles con código limpio y diseño innovador
    </p>
    <div class="botones-principal">
      <a href="#projects" class="boton-primario">Ver Proyectos</a>
      <a href="#contact" class="boton-secundario">Contactar</a>
    </div>
  </div>
</section>
